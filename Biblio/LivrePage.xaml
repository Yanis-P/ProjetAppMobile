<?xml version="1.0" encoding="utf-8" ?> <!--zob-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Biblio.LivrePage"
             Shell.BackgroundColor="DarkViolet"
             Shell.TitleColor="White"
             Title="LivrePage">



    <CollectionView x:Name="livres"
                SelectionMode="Single"
                SelectionChanged="livres_SelectionChanged"
                BackgroundColor="White"
     >
        <CollectionView.ItemTemplate>
            <DataTemplate>

                <Grid Padding="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image 
                        Grid.Column="0"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        WidthRequest="60"  
                        HeightRequest="60"
                        Source="{Binding IdLivre}"
                        Margin="0,0,10,0"
                        VerticalOptions="Center"/>

                    <Label 
                        Grid.Column="1"
                        Grid.Row="0"
                        Text="{Binding Name}"
                        TextColor="Black"
                        FontAttributes="Bold"
                        LineBreakMode="TailTruncation"/>

                    <Label 
                        Grid.Column="1"
                        Grid.Row="1"
                        Text="{Binding Description}"
                        TextColor="Black"
                        FontAttributes="Bold"
                        LineBreakMode="WordWrap"/>

                    <Label 
                        Grid.Column="1"
                        Grid.Row="2"
                        Text="{Binding IdCat}"
                        TextColor="Black"
                        FontAttributes="Bold"/>

                </Grid>

            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>