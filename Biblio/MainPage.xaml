<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Biblio.MainPage"
             Shell.BackgroundColor="White"
             Shell.TitleColor="Black"
             Title="Bibliothèque">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Ajouter">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIconsRegular" 
                        Glyph="&#xe88a;"
                        Color="Black"/>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
            <!-- Contenu de la grille -->
            <Label Text="Catégories" FontSize="24" FontAttributes="Bold" Grid.Row="0"/>
            <CollectionView Grid.Row="1" SelectionMode="Single">
                <!-- Bind vers vos catégories -->
            </CollectionView>
        </Grid>
    </ScrollView>

</ContentPage>
