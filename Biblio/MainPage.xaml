<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Biblio.MainPage"
             xmlns:local="clr-namespace:Biblio"
             Shell.BackgroundColor="DarkViolet"
             Shell.TitleColor="White"
             Title="Bibliothèque">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Ajouter" Clicked="Button_Clicked" x:Name="Déconnexion">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIconsRegular" 
                        Glyph="&#xe853;"
                        Color="Black"/>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <VerticalStackLayout>

        <CollectionView x:Name="lv"
                    SelectionMode="Single"
                    SelectionChanged="lv_SelectionChanged"
                    BackgroundColor="White"
         >
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Grid Padding="10">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image 
                                Grid.Column="0"
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                WidthRequest="60"  
                                HeightRequest="60"
                                Source="{Binding Image}"
                                Margin="0,0,10,0"
                                VerticalOptions="Center"/>

                        <Label 
                                Grid.Column="1"
                                Grid.Row="0"
                                Text="{Binding Name}"
                                TextColor="Black"
                                FontAttributes="Bold"
                                LineBreakMode="TailTruncation"/>

                        <Label 
                                Grid.Column="1"
                                Grid.Row="1"
                                Text="{Binding Description}"
                                TextColor="Black"
                                FontAttributes="Bold"
                                LineBreakMode="WordWrap"/>

                        <Label 
                                Grid.Column="1"
                                Grid.Row="2"
                                Text="{Binding Count}"
                                TextColor="Black"
                                FontAttributes="Bold"/>

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentPage>